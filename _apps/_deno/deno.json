{
  "minimumDependencyAge": "P7D",
  "lock": {
    "frozen": true
  },
  "tasks": {
    "dev": "deno run --allow-net --sloppy-imports --allow-read --watch main.ts",
    "build:go": "GOOS=js GOARCH=wasm go build -o ./bin/app.wasm ./main.go",
    "test": "deno run build:go && deno test --no-check --allow-read --allow-env --allow-net"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  }
}
